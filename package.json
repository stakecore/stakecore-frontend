{
  "name": "stakecore",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.34.1",
  "homepage": "stakecore.org",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-warnings vite",
    "build": "NODE_OPTIONS=--no-warnings vite build",
    "clean": "vite clean",
    "lint": "eslint .",
    "preview": "NODE_OPTIONS=--no-warnings vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "----------- openapi -----------------------": "",
    "openapi-fix": "sed -i \"s|BASE: *'',|BASE: 'https://backend.stakecore.org',|\" ./src/backendApi/core/OpenAPI.ts",
    "openapi-gen": "pnpm exec openapi -i ./openapi.json -o ./src/backendApi && pnpm openapi-fix",
    "----------- github pages deploy -----------": "",
    "build-all": "pnpm install && pnpm build && echo stakecore.org > dist/CNAME",
    "deploy": "pnpm build-all && gh-pages -d dist --no-history --nojekyll"
  },
  "dependencies": {
    "@remixicon/react": "^4.2.0",
    "bech32": "^2.0.0",
    "bootstrap": "^5.3.3",
    "buffer": "^6.0.3",
    "classnames": "^2.5.1",
    "ethers": "^6.13.5",
    "react": "^19.2.3",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.2.3",
    "react-router": "7.16.0",
    "react-router-dom": "7.16.0",
    "react-toastify": "^11.0.5",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.8.0",
    "spinners-react": "^1.0.11",
    "swr": "^2.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@metamask/providers": "^22.1.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/classnames": "^2.3.0",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.8.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.9",
    "gh-pages": "^6.3.0",
    "globals": "^17.1.0",
    "happy-dom": "^20.9.0",
    "openapi-typescript": "^7.6.1",
    "openapi-typescript-codegen": "^0.29.0",
    "sass-embedded": "^1.93.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "flatted": "^3.4.2",
      "handlebars": "^4.7.9",
      "immutable": "^5.1.5",
      "minimatch": "^5.1.8",
      "postcss": "^8.5.10",
      "rollup": "^4.59.0",
      "micromatch>picomatch": "^2.3.2",
      "tinyglobby>picomatch": "^4.0.4",
      "vite>picomatch": "^4.0.4",
      "uuid": "^11.1.1",
      "ws": "^8.20.1"
    }
  }
}
